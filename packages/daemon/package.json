{
  "name": "@agent-bay/daemon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "agent-bay": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'node dist/index.js start'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-bay/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
